{% extends 'base.html.twig' %}

{% block title %}{{ player.name }} - {{ parent() }}{% endblock %}

{% block body %}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('player_index') }}">Players</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ player.name }}</li>
        </ol>
    </nav>

    <div class="card mb-4">
        <div class="card-header">
            <h1 class="card-title h3 mb-0">{{ player.name }}</h1>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Country</dt>
                        <dd class="col-sm-8">
                            {% if player.country %}
                                <span class="badge bg-primary">{{ player.country }}</span>
                            {% else %}
                                <span class="text-muted">Unknown</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-4">External ID</dt>
                        <dd class="col-sm-8"><code>{{ player.externalId }}</code></dd>

                        <dt class="col-sm-4">Member since</dt>
                        <dd class="col-sm-8">{{ player.createdAt|date('F j, Y') }}</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Tournaments Played</dt>
                        <dd class="col-sm-6"><span class="badge bg-info fs-6">{{ stats.tournaments }}</span></dd>

                        <dt class="col-sm-6">Best Placement</dt>
                        <dd class="col-sm-6">
                            {% if stats.best_placing %}
                                <span class="badge bg-success fs-6">#{{ stats.best_placing }}</span>
                                {% if stats.best_placing_players %}
                                    <small class="text-muted">/ {{ stats.best_placing_players }}</small>
                                {% endif %}
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-6">Win Rate</dt>
                        <dd class="col-sm-6">
                            {% set total_games = stats.total_wins + stats.total_losses + stats.total_ties %}
                            {% if total_games > 0 %}
                                {% set win_rate = (stats.total_wins / total_games * 100)|round(1) %}
                                <span class="badge {{ win_rate >= 50 ? 'bg-success' : 'bg-warning text-dark' }} fs-6">
                                    {{ win_rate }}%
                                </span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-6">Overall Record</dt>
                        <dd class="col-sm-6">
                            <span class="text-success fw-bold">{{ stats.total_wins }}W</span>
                            -
                            <span class="text-danger fw-bold">{{ stats.total_losses }}L</span>
                            -
                            <span class="text-secondary fw-bold">{{ stats.total_ties }}T</span>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h4 mb-3">Tournament Results</h2>

    {% if results is empty %}
        <div class="alert alert-info">
            No tournament results found for this player.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tournament</th>
                        <th>Date</th>
                        <th>Format</th>
                        <th>Organizer</th>
                        <th class="text-center">Placement</th>
                        <th class="text-center">Record</th>
                        <th>Deck</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for result in results %}
                        <tr>
                            <td>
                                <strong>
                                    <a href="https://play.limitlesstcg.com/tournament/{{ result.tournament.externalId }}/details">
                                        {{ result.tournament.name }}
                                    </a>
                                </strong>
                                {% if result.tournament.isOnline is not null %}
                                    <span class="badge {{ result.tournament.isOnline ? 'bg-info' : 'bg-success' }} ms-1" title="{{ result.tournament.isOnline ? 'Online' : 'In-Person' }}">
                                        {{ result.tournament.isOnline ? 'Online' : 'IRL' }}
                                    </span>
                                {% endif %}
                                {% if result.tournament.structure %}
                                    <br>
                                    <small class="text-muted">
                                        {% for phase in result.tournament.structure %}
                                            {{ phase.type }}{% if phase.rounds > 1 %} ({{ phase.rounds }}R){% endif %}{% if phase.mode != 'BO1' %} {{ phase.mode }}{% endif %}{% if not loop.last %} + {% endif %}
                                        {% endfor %}
                                    </small>
                                {% endif %}
                            </td>
                            <td>{{ result.tournament.date|date('Y-m-d') }}</td>
                            <td>
                                <span class="badge bg-secondary">{{ result.tournament.game }}</span>
                                {% if result.tournament.format %}
                                    <span class="badge bg-primary">{{ result.tournament.format }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if result.tournament.organizerName %}
                                    {% if result.tournament.organizerLogo %}
                                        <img src="{{ result.tournament.organizerLogo }}" alt="{{ result.tournament.organizerName }}" class="me-1" style="height: 20px; width: auto;">
                                    {% endif %}
                                    <span>{{ result.tournament.organizerName }}</span>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if result.finalPlacing %}
                                    {% if result.finalPlacing <= 3 %}
                                        <span class="badge bg-warning text-dark fs-6">#{{ result.finalPlacing }}</span>
                                    {% elseif result.finalPlacing <= 8 %}
                                        <span class="badge bg-info fs-6">#{{ result.finalPlacing }}</span>
                                    {% else %}
                                        <span class="badge bg-light text-dark">#{{ result.finalPlacing }}</span>
                                    {% endif %}
                                    <small class="text-muted">/ {{ result.tournament.playerCount }}</small>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <span class="text-success">{{ result.wins }}</span>-<span class="text-danger">{{ result.losses }}</span>-<span class="text-secondary">{{ result.ties }}</span>
                            </td>
                            <td>
                                {% if result.deckIcons|length > 0 %}
                                    <a href="https://play.limitlesstcg.com/tournament/{{ result.tournament.externalId }}/player/{{ result.player.externalId }}/decklist" target="_blank" rel="noopener" title="{{ result.deckName ?? 'Decklist' }}" class="text-nowrap">
                                        {% for url in result.deckIconUrls -%}
                                            <img src="{{ url }}" alt="Pokemon icon" loading="lazy">
                                        {%- endfor %}
                                    </a>
                                {% else %}
                                    <span class="text-muted">Unknown</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if result.dropped %}
                                    <span class="badge bg-danger">Dropped</span>
                                {% else %}
                                    <span class="badge bg-success">Completed</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
