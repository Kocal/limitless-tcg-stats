{% extends 'base.html.twig' %}

{% block title %}Players - {{ parent() }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Players</h1>
        <span class="badge bg-secondary fs-6">{{ players|length }} player(s)</span>
    </div>

    {% if players is empty %}
        <div class="alert alert-info">
            No players found. Run the <code>limitless:stats:collect</code> command to fetch player data.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Country</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for player in players %}
                        <tr>
                            <td>
                                <a href="{{ path('player_show', {id: player.id}) }}" class="text-decoration-none fw-semibold">
                                    {{ player.name }}
                                </a>
                            </td>
                            <td>
                                {% if player.country %}
                                    <span class="badge bg-light text-dark">{{ player.country }}</span>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>{{ player.createdAt|date('Y-m-d') }}</td>
                            <td>
                                <a href="{{ path('player_show', {id: player.id}) }}" class="btn btn-sm btn-outline-primary">
                                    View Results
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
